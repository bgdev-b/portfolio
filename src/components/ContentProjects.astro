---
interface Project {
    name: string;
    description: string;
    github?: string;
    link: {
        url?: string;
        target?: string;
        title?: string;
        buttonLabel?: string;
    };
};

const projects: Project[] = [{
    name: 'Appointments Manager',
    description: 'A appointment management system designed to handle scheduling, state management, rescheduling flows, and business rules through a structured layered architecture and REST API approach.',
    github: 'https://github.com/bgdev-b/appointments-manager-full',
    link: {
        url: 'https://appointments-manager-full.vercel.app/appointments',
    }
}, {
    name: 'Operations Planner',
    description: 'A operations and scheduling management system focused on structured workflows, task organization, business logic handling, and scalable backend architecture through a layered REST API design.',
    github: 'https://github.com/bgdev-b/operation-planner',
    link: {
        url: 'https://operation-planner-s4px0n51h-bgdev-bs-projects.vercel.app/resources',
    }
}];
---

<div>

    <!-- <h2 class="text-2xl font-bold text-white mb-4">Latest Projects</h2> -->

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        {projects.map(project =>

            <div class="flex flex-col justify-center items-start border border-gray-700 rounded-lg p-4 bg-black">

                <h3 class="text-xl font-semibold text-white mb-2">
                    {project.name}
                </h3>

                <p class="text-gray-400">
                    {project.description}
                </p>

                {
                    project.link?.url ?
                        <a
                            href={project.link.url}
                            title={project.link.title || project.name}
                            target={project.link.target || '_blank'}
                            class="
                                w-full px-4 py-2.5 mt-4 text-center

                                border border-gray-600 rounded-lg

                                hover:text-primary
                                hover:border-primary
                            ">
                            {project.link.buttonLabel || 'Open Project Website'}
                        </a>
                    : null
                }

                {
                    project.github ?
                        <a
                            href={project.github}
                            title={'View source code for ' + project.name}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="
                                w-full px-4 py-2.5 mt-2 text-center

                                border border-gray-700 rounded-lg text-gray-400

                                hover:text-primary
                                hover:border-primary
                            ">
                            View on GitHub
                        </a>
                    : null
                }

            </div>

        )}

    </div>

</div>
